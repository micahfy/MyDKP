# 数据库配置
DATABASE_URL="file:/var/www/MyDKP/MyDKP-main/prisma/prod.db"

# 切换到 PostgreSQL 时使用:
# DATABASE_URL="postgresql://user:password@localhost:5432/wow_dkp?schema=public"

# 管理员认证
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="wow@admin123"

# Session 密钥 (生产环境请更换为随机字符串)
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"

# Cookie 配置：HTTPS 环境设为 true，内网/HTTP 设为 false
COOKIE_SECURE=false

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sensitive alert (keyword monitor)
SENSITIVE_ALERT_ENABLED=false
SENSITIVE_KEYWORD_FILE_PATH="./config/sensitive_keywords.txt"
SENSITIVE_TEXT_CACHE_SIZE=5000

# Sensitive alert mail worker
SENSITIVE_ALERT_MAIL_ENABLED=false
SENSITIVE_ALERT_RECIPIENTS="security@example.com"
SENSITIVE_ALERT_BATCH_SIZE=50
SENSITIVE_ALERT_MAX_ATTEMPTS=5
SENSITIVE_ALERT_RETRY_INTERVAL_SECONDS=300
SENSITIVE_ALERT_WORKER_INTERVAL_MS=15000

# Office365 (Microsoft Graph Mail.Send)
O365_TENANT_ID=""
O365_CLIENT_ID=""
O365_CLIENT_SECRET=""
O365_SENDER=""
