# Database
DATABASE_URL="file:/var/www/MyDKP/MyDKP-main/prisma/prod.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/wow_dkp?schema=public"

# Admin bootstrap
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="wow@admin123"
ADMIN_EMAIL=""

# Session
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"
COOKIE_SECURE=false

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Password reset
ADMIN_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
ADMIN_PASSWORD_RESET_MIN_INTERVAL_SECONDS=60

# Join request email verification
JOIN_REQUEST_CODE_TTL_MINUTES=10
JOIN_REQUEST_CODE_MIN_INTERVAL_SECONDS=60
JOIN_REQUEST_CODE_MAX_ATTEMPTS=5

# Generic mail defaults (optional)
MAIL_PROVIDER=""
MAIL_DEFAULT_FROM_ADDRESS=""
MAIL_DEFAULT_FROM_NAME=""

# Sensitive alert (keyword monitor)
SENSITIVE_ALERT_ENABLED=false
SENSITIVE_KEYWORD_FILE_PATH="./config/sensitive_keywords.txt"
SENSITIVE_TEXT_CACHE_SIZE=5000

# Sensitive alert mail worker
SENSITIVE_ALERT_MAIL_ENABLED=false
SENSITIVE_ALERT_RECIPIENTS="security@example.com"
SENSITIVE_ALERT_MAIL_PROVIDER=""
SENSITIVE_ALERT_BATCH_SIZE=50
SENSITIVE_ALERT_MAX_ATTEMPTS=5
SENSITIVE_ALERT_RETRY_INTERVAL_SECONDS=300
SENSITIVE_ALERT_WORKER_INTERVAL_MS=60000

# SMTP (simple option, recommended for personal/family mailbox)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_REQUIRE_TLS=false
SMTP_ALLOW_SELF_SIGNED_CERTS=false

# Office365 (Microsoft Graph Mail.Send)
O365_TENANT_ID=""
O365_CLIENT_ID=""
O365_CLIENT_SECRET=""
O365_SENDER=""
O365_FROM_ADDRESS=""
O365_FROM_NAME=""
